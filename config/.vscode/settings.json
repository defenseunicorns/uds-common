{
  "debug.javascript.terminalOptions": {
    "enableTurboSourcemaps": true,
    "resolveSourceMapLocations": [
      "${workspaceFolder}/**",
      "node_modules/kubernetes-fluent-client/**",
      "node_modules/pepr/**"
    ]
  },
  "yaml.schemas": {
    "https://raw.githubusercontent.com/defenseunicorns/uds-cli/v0.30.3/uds.schema.json": [
      "uds-bundle.yaml"
    ],
    "https://raw.githubusercontent.com/defenseunicorns/uds-cli/v0.30.3/tasks.schema.json": [
      "tasks.yaml",
      "tasks/**/*.yaml",
      "src/**/validate.yaml"
    ],
    "https://raw.githubusercontent.com/defenseunicorns/zarf/v0.75.0/zarf.schema.json": [
      "zarf.yaml"
    ],
    "https://raw.githubusercontent.com/defenseunicorns/uds-core/main/schemas/package-v1alpha1.schema.json": [
      "**/package.yaml",
      "**/uds-package.yaml"
    ],
    "https://raw.githubusercontent.com/defenseunicorns/uds-core/main/schemas/exemption-v1alpha1.schema.json": [
      "**/uds-exemption.yaml",
      "**/exemptions.yaml",
      "**/exemption.yaml"
    ]
  },
  "cSpell.words": [
    "alertmanager",
    "Authservice",
    "automount",
    "controlplane",
    "crds",
    "distros",
    "ironbank",
    "Kiali",
    "Kyverno",
    "MITM",
    "neuvector",
    "opensource",
    "promtail",
    "Quickstart",
    "Gitlab",
    "seccomp",
    "Sysctls",
    "Velero"
  ]
}
